eu_control$GDPpc,
breaks = "FD",
freq = FALSE,
right = FALSE,
plot = TRUE
)
plot(
h$mids, h$density,
type = "l",
lwd = 2,
xlab = "GDP per cap",
ylab = "Density"
)
# Total observations
n <- sum(h$counts)
# Bin widths
binwidth <- diff(h$breaks)
# Manual density calculation
density_manual <- h$counts / (n * binwidth)
# Verification table
density_check <- data.frame(
bin_left   = h$breaks[-length(h$breaks)],
bin_right  = h$breaks[-1],
midpoint   = h$mids,
count      = h$counts,
binwidth   = binwidth,
density_R  = h$density,
density_manual = density_manual,
diff = h$density - density_manual
)
density_check
delta_2=20000-10000
density_2=18/(sum(h$counts)*delta_2)
density_2
