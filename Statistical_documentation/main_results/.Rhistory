library(dplyr)
library(fixest)
# --- core helper: filter to treated + a chosen control set, then run pooled DiD ---
run_pooled_did <- function(df, treated_vec, control_vec,
y = "Applicants",
post_year = 2021,
vcov_type = "DK") {
df2 <- df %>%
filter(Domicile_named_country %in% c(treated_vec, control_vec)) %>%
mutate(
EU   = as.integer(Domicile_named_country %in% treated_vec),
Post = as.integer(Year >= post_year)
)
m <- feols(
as.formula(paste0(
"log(", y, ") ~ EU:Post | Domicile_named_country + Year"
)),
data = df2,
panel.id = ~Domicile_named_country + Year,
vcov = vcov_type
)
return(list(model = m, data = df2))
}
run_Poisson_did <- function(df, treated_vec, control_vec,
y = "Applicants",
post_year = 2021,
vcov_type = "DK") {
df2 <- df %>%
dplyr::filter(Domicile_named_country %in% c(treated_vec, control_vec)) %>%
dplyr::mutate(
EU = Domicile_named_country %in% treated_vec,
Post = Year >= post_year,
Treat_Post = EU * Post
)
formula <- as.formula(
paste0(y, " ~ Treat_Post | Domicile_named_country + Year")
)
m <- fixest::fepois(
formula,
data = df2,
panel.id = ~ Domicile_named_country + Year,
vcov = vcov_type
)
list(model = m, data = df2)
}
controls_list <- list(
"Original synthetic" = eu_synth,
"Very poor controls" = synth_poor,
"Very rich controls" = synth_rich,
"OECD controls"      = setdiff(oecd, eu_real)  # keep OECD but remove treated EU from control pool
)
fits <- lapply(names(controls_list), function(nm) {
run_pooled_did(
df = data[data$Year>2015,],
treated_vec = eu_real,
control_vec = controls_list[[nm]],
y = "Applicants",
post_year = 2021,
vcov_type = "DK"
)$model
})
fits_pois <- lapply(names(controls_list), function(nm) {
run_Poisson_did(
df = data[data$Year>2015,],
treated_vec = eu_real,
control_vec = controls_list[[nm]],
y = "Applicants",
post_year = 2021,
vcov_type = "DK"
)$model
})
names(fits) <- names(controls_list)
names(fits_pois) <- names(controls_list)
